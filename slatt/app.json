{
  "expo": {
    "name": "Slatt",
    "description": "slatt is collective intelligence that grows smarter as people teach it. Ask questions, get verified answers, and contribute what you know — fact-checked or from real personal experience.",
    "sdkVersion": "54.0.0",
    "slug": "slatt",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "slatt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.voidback.slatt",
      "buildNumber": "1",
      "version": "1.1.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow slatt to use Face ID to confirm your identity when deleting your account."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b9acf4f-451a-41a2-91fa-26344bce720b"
      }
    },
    "owner": "voidback-inc"
  }
}
